        "format": "<div style=\"padding: 10px; display: flex; flex-direction: column; gap: 15px;\" ng-init=\"my_sv=''; my_sl=1; my_act='borrow'\">\n    <div>\n        <label style=\"font-weight:bold; color:#333;\">Tên / Mã SV</label><br>\n        <input type=\"text\" ng-model=\"my_sv\" placeholder=\"Nhập tên...\" style=\"width:100%; padding:10px; border:1px solid #ccc; border-radius:4px; margin-top:5px; font-size:16px;\">\n    </div>\n    <div>\n        <label style=\"font-weight:bold; color:#333;\">Số lượng</label><br>\n        <input type=\"number\" ng-model=\"my_sl\" style=\"width:100%; padding:10px; border:1px solid #ccc; border-radius:4px; margin-top:5px; font-size:16px;\">\n    </div>\n    <div>\n        <label style=\"font-weight:bold; color:#333;\">Hành động</label><br>\n        <select ng-model=\"my_act\" style=\"width:100%; padding:10px; border:1px solid #ccc; border-radius:4px; margin-top:5px; font-size:16px;\">\n            <option value=\"borrow\">📗 Mượn sách</option>\n            <option value=\"return\">📘 Trả sách</option>\n            <option value=\"sleep\">💤 Đi ngủ</option>\n            <option value=\"eat\">🍜 Ăn cơm</option>\n            <option value=\"secret\"> Địa điểm bí ẩn?</option>\n        </select>\n    </div>\n    <button ng-click=\"send({payload: {ma_sv: my_sv, so_luong: my_sl, action: my_act}})\" style=\"padding:12px; background-color:#009688; color:white; border:none; border-radius:4px; cursor:pointer; font-weight:bold; font-size:16px;\">\n        THỰC HIỆN\n    </button>\n</div>",
