        "format": "<div style=\"text-align: center; width: 100%;\">\n    <img id=\"secret-img\" src=\"\" style=\"width: 100%; max-height: 450px; object-fit: contain; border-radius: 10px; display: none; box-shadow: 0 8px 16px rgba(0,0,0,0.4);\">\n</div>\n<script>\n    (function(scope) {\n        scope.$watch('msg', function(msg) {\n            if (msg && msg.payload) {\n                var img = document.getElementById('secret-img');\n                if (msg.payload === 'clear') {\n                    img.style.display = 'none';\n                } else {\n                    img.src = msg.payload;\n                    img.style.display = 'block';\n                }\n            }\n        });\n    })(scope);\n</script>",
